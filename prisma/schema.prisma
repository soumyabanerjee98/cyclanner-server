// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  email       String?  @unique
  password    String
  name        String?

  age         Int?
  maxHR       Int?
  restingHR   Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stravaToken StravaToken?
  activities  Activity[]
}

model StravaToken {
  id           String   @id @default(uuid())

  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])

  accessToken  String
  refreshToken String
  expiresAt    Int
  athleteId    BigInt   @unique
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@unique([userId, isActive])
}

model Activity {
  id                   BigInt  @id  // Strava activity ID

  userId               String
  user                 User    @relation(fields: [userId], references: [id])

  name                 String?
  type                 String?

  distance             Float    // meters
  movingTime           Int      // seconds
  elapsedTime          Int?

  avgHR                Int?
  maxHR                Int?

  zone                 String?   // z1, z2, z3, z4, z5
  trainingLoad         Float?    // computed metric

  elevationGain        Float?

  startDate            DateTime
  timezone             String?

  createdAt            DateTime @default(now())

  @@index([userId])
  @@index([startDate])
}
