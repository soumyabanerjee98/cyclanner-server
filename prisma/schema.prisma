// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  email       String?  @unique
  password    String
  name        String?

  age         Int?
  maxHR       Int?
  restingHR   Int?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stravaToken StravaToken?
  activities  Activity[]

  currentGoalId String?

  goals     Goal[] @relation("UserGoals")
  insights  DailyInsight[]
}

model StravaToken {
  id           String   @id @default(uuid())

  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])

  accessToken  String
  refreshToken String
  expiresAt    Int
  athleteId    BigInt   @unique
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@unique([userId, isActive])
}

model Activity {
  id                   BigInt  @id  // Strava activity ID

  userId               String
  user                 User    @relation(fields: [userId], references: [id])

  name                 String?
  type                 String?

  distance             Float    // meters
  movingTime           Int      // seconds
  elapsedTime          Int?

  avgHR                Int?
  maxHR                Int?

  zone                 String?   // z1, z2, z3, z4, z5
  trainingLoad         Float?    // computed metric

  elevationGain        Float?

  startDate            DateTime
  timezone             String?

  createdAt            DateTime @default(now())

  @@index([userId])
  @@index([startDate])
}

model Goal {
  id String @id @default(uuid())

  userId String
  user   User   @relation("UserGoals", fields: [userId], references: [id])

  weekStart DateTime
  weekEnd   DateTime

  currentLoad  Float
  targetLoad   Float
  adjustedLoad Float
  fatigue      Float

  status       String? // on_track, overtrained, undertrained

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt 

  plan          Plan[]
  insights      DailyInsight[]
  weeklySummary WeeklySummary?

  @@index([userId])
  @@index([weekStart])

  @@unique([userId, weekStart])
}

model Plan {
  id        String   @id @default(uuid())

  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id])

  day       String   // Mon, Tue...
  type      String   // rest, easy, hard, long, recovery

  load      Float

  version   Int      @default(1)
  isAdjusted Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([goalId])
  @@unique([goalId, day, version])
}

model DailyInsight {
  id        String   @id @default(uuid())

  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  date      DateTime

  plannedLoad Float
  actualLoad  Float
  deviation   Float

  status String // overtrained, undertrained, on_track

  fatigueScore Float?
  strainScore  Float?

  commentary String?

  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([goalId])
  @@index([date])
}

model WeeklySummary {
  id        String   @id @default(uuid())

  goalId    String   @unique
  goal      Goal     @relation(fields: [goalId], references: [id])

  plannedLoad Float
  actualLoad  Float
  balance     Float

  adherenceScore Float
  trend         String // improving, overreaching, stable

  fatigueRisk   String // low, medium, high

  createdAt     DateTime @default(now())
}
