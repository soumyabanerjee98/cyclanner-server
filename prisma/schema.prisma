// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String? @unique
  password String
  name     String?

  age       Int?
  maxHR     Int?
  restingHR Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stravaToken StravaToken?
  activities  Activity[]

  currentGoalId String?

  goals    Goal[]         @relation("UserGoals")
  insights DailyInsight[]
}

model StravaToken {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  accessToken  String
  refreshToken String
  expiresAt    Int
  athleteId    BigInt  @unique
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, isActive])
  @@index([userId])
}

model Activity {
  id BigInt @id // Strava activity ID

  userId String
  user   User   @relation(fields: [userId], references: [id])

  name String?

  distance    Float // meters
  movingTime  Int // seconds
  elapsedTime Int?

  avgHR Int?
  maxHR Int?

  avgSpeed Float // mps
  maxSpeed Float // mps

  calories Int?

  avgWatts   Float?
  kilojoules Float

  zone                 String? // z1, z2, z3, z4, z5
  trainingLoad         Float? // computed metric
  trainingLoadSource   String // ActivityMetricSource enums
  trainingLoadAccuracy String // ActivityMetricAccuracy enums

  elevationGain Float?

  startDate DateTime
  timezone  String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([startDate])
}

model Goal {
  id String @id @default(uuid())

  userId String
  user   User   @relation("UserGoals", fields: [userId], references: [id])

  startDate DateTime
  endDate   DateTime

  experienceLevel String

  customGoalRequest String?

  currentLoad  Float
  targetLoad   Float
  adjustedLoad Float

  fatigue   Float // ATL
  fitness   Float // CTL
  readiness Float // TSB

  status String? // on_track, overtrained, undertrained

  isActive    Boolean @default(true)
  isCompleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plan        Plan[]
  insights    DailyInsight[]
  goalSummary GoalSummary?

  @@unique([userId, startDate, endDate])
  @@index([userId])
  @@index([startDate])
  @@index([endDate])
  @@index([isActive])
}

model Plan {
  id String @id @default(uuid())

  goalId String
  goal   Goal   @relation(fields: [goalId], references: [id])

  date DateTime
  type String // rest  recovery  endurance easy  tempo threshold VO2 sprint  long

  title       String
  description String

  instructions String?

  targetLoad Float

  targetDistance Float?
  targetDuration Int?

  completed Boolean @default(false)

  completedAt DateTime?

  actualLoad Float?

  createdAt DateTime @default(now())

  @@unique([goalId, date])
  @@index([goalId])
  @@index([date])
  @@index([type])
}

model DailyInsight {
  id String @id @default(uuid())

  goalId String
  goal   Goal   @relation(fields: [goalId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  date DateTime

  plannedLoad Float
  actualLoad  Float
  deviation   Float

  status String // overtrained, undertrained, on_track

  fatigueScore Float?
  strainScore  Float?

  commentary String?

  createdAt DateTime @default(now())

  @@unique([userId, date], name: "userId_date")
  @@index([goalId])
  @@index([date])
}

model GoalSummary {
  id String @id @default(uuid())

  goalId String @unique
  goal   Goal   @relation(fields: [goalId], references: [id])

  plannedLoad Float
  actualLoad  Float
  balance     Float

  adherenceScore Float
  trend          String // improving, overreaching, stable

  fatigueRisk String // low, medium, high

  aiSummary         String?
  aiPositives       Json?
  aiIssues          Json?
  aiCurrentState    String?
  aiRecommendations Json?

  createdAt DateTime @default(now())
}
